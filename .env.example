# Required: Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Required: Your Telegram Chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your-chat-id-here

# Optional: Path to Claude CLI binary (default: /opt/homebrew/bin/claude)
# CLAUDE_PATH=/opt/homebrew/bin/claude

# Optional: Default working directory for Claude sessions
# Defaults to the claude-bot project directory (recommended)
# CLAUDE_WORKSPACE=/path/to/your/workspace
