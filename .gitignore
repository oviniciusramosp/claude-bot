# ============================================
# Secrets & credentials
# ============================================
.env
vault/.env

# ============================================
# Vault — personal content (not shared)
# Only .gitkeep files are tracked to preserve
# the directory structure for new users.
# ============================================
vault/Journal/*
!vault/Journal/.gitkeep
!vault/Journal/Journal.md
vault/Notes/*
!vault/Notes/.gitkeep
!vault/Notes/Notes.md
vault/Images/*
!vault/Images/.gitkeep
vault/Skills/*
!vault/Skills/.gitkeep
!vault/Skills/Skills.md
!vault/Skills/create-routine.md
!vault/Skills/create-agent.md
!vault/Skills/import-agent.md
!vault/Skills/create-pipeline.md
!vault/Skills/extract-knowledge.md
vault/Routines/*
!vault/Routines/.gitkeep
!vault/Routines/Routines.md.template
!vault/Routines/update-check.md
!vault/Routines/journal-audit.md
!vault/Routines/vault-graph-update.md
!vault/Routines/vault-lint.md
!vault/Routines/vault-indexes-update.md
vault/Agents/*
!vault/Agents/.gitkeep
!vault/Agents/Agents.md.template

# Knowledge graph (generated)
vault/.graphs/
graphify-out/

# Obsidian workspace state (user-specific)
vault/.obsidian/workspace.json
vault/.obsidian/graph.json

# Claude Code local settings (user-specific paths)
.claude/settings.local.json
# Claude Code implementation plans (user-local, may contain hardcoded paths)
.claude/plans/
# Claude Code session state
.claude/todos/
.claude/history/

# ============================================
# Runtime data
# ============================================
*.log
sessions.json

# ============================================
# macOS
# ============================================
.DS_Store

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
